# Vercel AI Gateway (preferred — routes to any provider via "provider/model" strings)
# Get one at https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=

# Direct provider fallbacks (used only if AI_GATEWAY_API_KEY is not set)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Override the default model (default: anthropic/claude-sonnet-4-6)
# AI_MODEL=anthropic/claude-sonnet-4-6

# Override the playground server port (default: 3030)
# PLAYGROUND_SERVER_PORT=3030
