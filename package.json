{
  "name": "@baruch-eric/stream-ui",
  "version": "0.8.0",
  "description": "Flexible UI framework that streams UI to the user, guided by an AI agent",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BaruchEric/stream-ui.git"
  },
  "homepage": "https://github.com/BaruchEric/stream-ui#readme",
  "bugs": {
    "url": "https://github.com/BaruchEric/stream-ui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "tokens": "bun run scripts/design-to-css.ts",
    "lint:design": "bun run scripts/lint-design.ts",
    "diff:design": "bunx @google/design.md@latest diff",
    "build": "bun run tokens && tsup src/index.ts --format esm --dts --clean && bun run scripts/build-styles.ts",
    "dev": "bun run tokens && tsup src/index.ts --format esm --dts --watch --onSuccess \"bun run scripts/build-styles.ts\"",
    "playground": "bun run tokens && vite",
    "playground:build": "vite build",
    "playground:server": "bun run --watch playground/server.ts",
    "playground:full": "bun run playground/scripts/run-full.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "prepublishOnly": "bun run build"
  },
  "keywords": ["ui", "framework", "ai", "ai-agent", "streaming", "generative-ui"],
  "author": "Eric Baruch",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/bun": "latest",
    "@vercel/node": "^5.7.13",
    "ai": "^6.0.168",
    "happy-dom": "^20.9.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.5",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "trustedDependencies": ["@biomejs/biome"]
}
